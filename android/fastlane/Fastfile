# Fastfile for automated Play Store deployment
# Documentation: https://docs.fastlane.tools

default_platform(:android)

platform :android do

  desc "Build and upload AAB to Play Store Internal Testing"
  lane :internal do
    # Build the release bundle
    sh("cd ../.. && flutter clean && flutter pub get && flutter build appbundle --release")

    # Upload to Play Store Internal Testing track
    upload_to_play_store(
      track: 'internal',
      aab: '../build/app/outputs/bundle/release/app-release.aab',
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      json_key: 'android/fastlane/play-store-credentials.json'
    )
  end

  desc "Build and upload AAB to Play Store Alpha"
  lane :alpha do
    sh("cd ../.. && flutter clean && flutter pub get && flutter build appbundle --release")

    upload_to_play_store(
      track: 'alpha',
      aab: '../build/app/outputs/bundle/release/app-release.aab',
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      json_key: 'android/fastlane/play-store-credentials.json'
    )
  end

  desc "Build and upload AAB to Play Store Beta"
  lane :beta do
    sh("cd ../.. && flutter clean && flutter pub get && flutter build appbundle --release")

    upload_to_play_store(
      track: 'beta',
      aab: '../build/app/outputs/bundle/release/app-release.aab',
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      json_key: 'android/fastlane/play-store-credentials.json'
    )
  end

  desc "Promote from Internal to Alpha"
  lane :promote_to_alpha do
    upload_to_play_store(
      track: 'internal',
      track_promote_to: 'alpha',
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      json_key: 'android/fastlane/play-store-credentials.json'
    )
  end

  desc "Just build the AAB (no upload)"
  lane :build_only do
    sh("cd ../.. && flutter clean && flutter pub get && flutter build appbundle --release")
  end
end
